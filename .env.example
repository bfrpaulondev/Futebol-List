# ============================================================
# Futebol Bonfim - Environment configuration
# ============================================================
# Copy this file to .env and adjust values for your environment.
#
# TWO DATABASE MODES ARE SUPPORTED (auto-detected from DATABASE_URL):
#
# 1. LOCAL DEVELOPMENT (default) — local SQLite file
#    Use a "file:" URL. The database file is created at db/custom.db.
#    Works great locally. DO NOT use in serverless (Vercel/Netlify):
#    the filesystem is ephemeral and ALL data (chat messages, accounts,
#    games) is lost on every cold start.
#
# 2. PRODUCTION (serverless / Vercel) — Turso (libSQL)
#    Use a "libsql://" URL from https://turso.tech and set TURSO_AUTH_TOKEN.
#    Data persists across cold starts. This is the recommended backend for
#    any deployment where the filesystem is not persistent.
#
# The same codebase runs in both modes — only the env vars change.
# ============================================================

# --- LOCAL DEVELOPMENT (default) ---
DATABASE_URL="file:../db/custom.db"

# --- PRODUCTION (Turso / libSQL) — uncomment and fill in ---
# Get these from https://app.turso.tech -> your database -> Settings
# DATABASE_URL="libsql://your-database-name-your-org.turso.io"
# TURSO_AUTH_TOKEN="your-turso-access-token"

# --- JWT secret (REQUIRED in production) ---
# Used to sign auth tokens. The default below is INSECURE — override it
# in production with a strong random string (>= 32 chars).
JWT_SECRET=""

# --- OpenAI API key (OPTIONAL) ---
# Powers the "Palestrinha" AI features (post-game chronicles, pre-game
# summaries, weekly reviews, complaint responses). If empty or invalid,
# these features degrade gracefully with friendly fallback text.
OPENAI_API_KEY=""
